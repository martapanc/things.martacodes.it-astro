---
import SiteLayout from '@/layouts/SiteLayout.astro';
import TravelBoard from '@/components/TravelBoard';
import 'flag-icons/css/flag-icons.min.css';
---

<SiteLayout title='Travel | Marta Makes Things' headerText='Marta Travels'>
    <div class='border-b border-slate-200 pb-4 mb-6 dark:border-slate-700'>
        <h1>Pics from around the World</h1>
        <p class='mt-1 text-slate-500 dark:text-slate-400'>Places visited, moments captured</p>
    </div>

    <TravelBoard client:load />
</SiteLayout>
