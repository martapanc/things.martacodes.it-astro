---
import SiteLayout from '@/layouts/SiteLayout.astro';
import FoodGallery from '@/components/FoodGallery';
import { getFoodImages } from '@/lib/cloudinary';

const photos = await getFoodImages();
---

<SiteLayout title='Food | Marta Makes Things' headerText='Marta Cooks'>
    <div class='border-b border-slate-200 pb-4 mb-6 dark:border-slate-700'>
        <h1>Adventures in the kitchen</h1>
        <p class='mt-1 text-slate-500 dark:text-slate-400'>Recipes, experiments and edible results</p>
    </div>

    <FoodGallery photos={photos} client:load />
</SiteLayout>
