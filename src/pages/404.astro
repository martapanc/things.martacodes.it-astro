---
import SiteLayout from '@/layouts/SiteLayout.astro';
---

<SiteLayout title='Page Not Found | Marta Makes Things'>
    <div class='flex min-h-[50vh] flex-col items-center justify-center gap-6 text-center'>
        <h1 class='text-6xl font-bold text-indigo-500'>404</h1>
        <h2 class='text-2xl'>Page Not Found</h2>
        <p class='text-slate-600 dark:text-slate-400'>
            The page you're looking for doesn't exist.
        </p>
        <a
            href='/blog'
            class='rounded-lg bg-indigo-600 px-6 py-3 text-white hover:bg-indigo-700 transition-colors'
        >
            Back to Blog
        </a>
    </div>
</SiteLayout>
