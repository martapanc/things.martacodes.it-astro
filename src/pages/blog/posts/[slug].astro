---
import { getCollection, render } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import PostHeader from '@/components/PostHeader.astro';
import { Comments } from '@/components/Comments';
import { allCategories } from '@/types/Post';
import '@/styles/aoc.scss';

export async function getStaticPaths() {
    const posts = await getCollection('posts', ({ data }) => data.published);

    // Sort by date ascending to determine prev/next
    const sorted = posts.sort(
        (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
    );

    return sorted.map((entry, index) => {
        const prev = index > 0 ? sorted[index - 1] : null;
        const next = index < sorted.length - 1 ? sorted[index + 1] : null;

        return {
            params: { slug: entry.id },
            props: {
                entry,
                previous: prev
                    ? { slug: prev.id, title: prev.data.title }
                    : null,
                next: next
                    ? { slug: next.id, title: next.data.title }
                    : null,
            },
        };
    });
}

const { entry, previous, next } = Astro.props;
const { Content, headings } = await render(entry);

const tocHeadings = entry.data.toc ? headings : [];

const breadcrumbs = {
    past: [
        { path: '/blog', label: 'Blog' },
        {
            path: `/blog/categories/${entry.data.category ?? 'uncategorized'}`,
            label: allCategories[entry.data.category] ?? 'Uncategorized',
        },
    ],
    current: entry.data.title,
};
---

<BlogLayout
    title={`${entry.data.title} | Marta Makes Things`}
    description={entry.data.description}
    image={entry.data.image}
    breadcrumbs={breadcrumbs}
    headings={tocHeadings}
    previous={previous}
    next={next}
    showComments={true}
>
    <PostHeader entry={entry} body={entry.body ?? ''} />

    <article>
        <Content />
    </article>

    <Comments client:visible slot='comments' />
</BlogLayout>
