---
interface Props {
    headings: {
        depth: number;
        text: string;
        slug: string;
    }[];
}

const { headings } = Astro.props;
---

<h3>Table of Contents</h3>
<ul class='mt-2'>
    {
        headings.map((heading) => (
            <li
                class='text-xs font-semibold hover:text-indigo-500'
                style={`margin-left: ${(heading.depth - 1) * 10}px`}
            >
                <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
        ))
    }
</ul>
