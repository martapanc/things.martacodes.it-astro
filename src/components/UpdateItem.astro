---
import { render, type CollectionEntry } from 'astro:content';
import BgIcon from '@/components/atoms/BgIcon.astro';
import {formatDate} from "@/lib/posts.ts";

interface Props {
    update: CollectionEntry<'updates'>;
}

const { update } = Astro.props;
const { Content } = await render(update);

const formattedDate = formatDate(update.data.date);
---

<div
    id={update.id}
    data-tags={update.data.tags.join(',')}
    class='duration-400 h-auto rounded-2xl border border-slate-200 bg-white p-4 transition ease-in-out hover:-translate-y-0.5 hover:shadow-md dark:border-slate-700/50 dark:bg-slate-900 drop-shadow-sm'
>
    <div class='flex h-full flex-col gap-5 lg:flex-row'>
        <div
            class='relative flex h-72 w-full overflow-hidden rounded-xl lg:h-auto lg:w-[20rem] xl:w-[16rem]'
        >
            <img
                alt='Update image'
                src={update.data.image ?? 'https://picsum.photos/300/250'}
                class='absolute left-0 top-0 h-full w-full rounded-xl object-cover'
            />
        </div>
        <div class='flex h-full w-full flex-col justify-between'>
            <div>
                <div class='mb-2 flex flex-row items-start justify-between'>
                    <span class='flex justify-end gap-1 italic'>
                        <BgIcon icon='material-symbols:calendar-month-rounded' />
                        {formattedDate}
                    </span>

                    {
                        update.data.tags && update.data.tags.length > 0 && (
                            <div class='hidden sm:flex flex-wrap gap-1'>
                                <BgIcon icon='fa6-solid:hashtag' accent />
                                {update.data.tags.map((tag) => (
                                    <a
                                        href={`/updates?tags=${tag}`}
                                        class='rounded-full border border-indigo-200 bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-600 transition-colors hover:bg-indigo-100 dark:border-indigo-800 dark:bg-indigo-950/50 dark:text-indigo-400 dark:hover:bg-indigo-900/50'
                                    >
                                        {tag}
                                    </a>
                                ))}
                            </div>
                        )
                    }
                </div>

                <div class='mb-3'>
                    <h2>{update.data.title}</h2>
                </div>

                <div
                    class='update-body mb-2 h-fit font-updates text-sm sm:mb-4'
                >
                    <Content />
                </div>

                {
                    update.data.tags && update.data.tags.length > 0 && (
                        <div class='flex justify-end sm:hidden flex-wrap gap-1'>
                            <BgIcon icon='fa6-solid:hashtag' accent />
                            {update.data.tags.map((tag) => (
                                <a
                                    href={`/updates?tags=${tag}`}
                                    class='rounded-full border border-indigo-200 bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-600 transition-colors hover:bg-indigo-100 dark:border-indigo-800 dark:bg-indigo-950/50 dark:text-indigo-400 dark:hover:bg-indigo-900/50'
                                >
                                    {tag}
                                </a>
                            ))}
                        </div>
                    )
                }
            </div>
        </div>
    </div>
</div>
