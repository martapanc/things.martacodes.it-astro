---
interface Props {
    href: string;
    class?: string;
    'aria-label'?: string;
    [key: string]: unknown;
}

const { href, class: className, ...rest } = Astro.props;

const isNewTab =
    href && !href.startsWith('/') && !href.startsWith('#');
---

{
    isNewTab ? (
        <a
            href={href}
            target='_blank'
            rel='noopener noreferrer'
            class={`cursor-newtab ${className ?? ''}`}
            {...rest}
        >
            <slot />
        </a>
    ) : (
        <a href={href} class={className} {...rest}>
            <slot />
        </a>
    )
}
