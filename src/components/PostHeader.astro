---
import { allCategories, allTags } from '@/types/Post';
import { calcWordsAndReadingTime, formatDate } from '@/lib/posts';
import BgIcon from '@/components/atoms/BgIcon.astro';
import PostImage from '@/components/PostImage';
import type { CollectionEntry } from 'astro:content';

interface Props {
    entry: CollectionEntry<'posts'>;
    body: string;
}

const { entry, body } = Astro.props;
const { title, category, tags, description, date, image } = entry.data;

const { wordCount, readingTime } = calcWordsAndReadingTime(body);
const formattedDate = formatDate(date);
---

<!-- Category / Tags / Date row -->
<div class='flex flex-col-reverse justify-start gap-1 sm:flex-row sm:justify-between'>
    <div class='flex flex-col gap-1 md:flex-row md:gap-5'>
        <span class='flex gap-1.5'>
            <BgIcon icon='fa6-solid:tag' accent />
            <a
                class='flex items-center text-sm font-medium text-blue-950 hover:text-blue-800 dark:text-gray-200'
                href={`/blog/categories/${category ?? 'uncategorized'}`}
                aria-label={allCategories[category]}
            >
                {allCategories[category] ?? 'Uncategorized'}
            </a>
        </span>

        {
            tags && tags.length > 0 && (
                <div class='flex flex-wrap gap-1'>
                    <BgIcon icon='fa6-solid:hashtag' accent />
                    {tags.map((tag, index) => (
                        <span class='flex items-center gap-0.5'>
                            <a
                                href={`/blog/tags/${tag}`}
                                class='flex items-center text-sm font-medium text-blue-950 hover:text-blue-800 dark:text-gray-200'
                            >
                                {allTags[tag]}
                            </a>
                            {index !== tags.length - 1 && (
                                <span class='px-0.5 text-slate-900/50 dark:text-slate-50/50'>
                                    /
                                </span>
                            )}
                        </span>
                    ))}
                </div>
            )
        }
    </div>

    <span class='flex gap-1 italic'>
        <BgIcon icon='material-symbols:calendar-month-rounded' />
        {formattedDate}
    </span>
</div>

<!-- Title + reading time -->
<div class='flex flex-col'>
    <h1 class='mb-4 mt-2'>{title}</h1>

    <div class='flex gap-5 text-sm'>
        <span class='flex gap-1.5'>
            <BgIcon icon='bi:text-left' size='sm' />
            {wordCount} words
        </span>
        <span class='flex gap-1.5'>
            <BgIcon icon='material-symbols:timer-outline' size='sm' />
            {readingTime}
        </span>
    </div>
</div>

<!-- Hero image -->
{
    image && (
        <div class='mb-4 mt-2 flex justify-center'>
            <PostImage src={image} alt='Post preview image' client:load />
        </div>
    )
}

<!-- Description lead -->
<div class='my-6 text-xl font-semibold'>{description}</div>
